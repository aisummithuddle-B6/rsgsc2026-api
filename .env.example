APP_NAME="Insurance RMIS API"
API_V1_PREFIX="/api/v1"

# Azure DocumentDB / Cosmos DB for MongoDB compatibility.
# Do not commit real credentials. Set this value in your local .env or hosting environment.
AZURE_DOCUMENTDB_CONNECTION_STRING="mongodb://<username>:<password>@<account>.documents.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@<account>@"
AZURE_DOCUMENTDB_DATABASE_NAME="rmis"
